**最小 RAG demo(打通链路,后面阶段都改它)**:

```python
# rag_min.py
from langchain_ollama import OllamaLLM, OllamaEmbeddings
from langchain_community.vectorstores import Chroma
from langchain_text_splitters import RecursiveCharacterTextSplitter

def build_rag(docs: list[str]):
    emb = OllamaEmbeddings(model="nomic-embed-text")
    splitter = RecursiveCharacterTextSplitter(chunk_size=500, chunk_overlap=50)
    chunks = splitter.create_documents(docs)
    vs = Chroma.from_documents(chunks, emb)
    llm = OllamaLLM(model="llama3.1:8b", temperature=0)  # 评测固定 temperature=0
    def ask(q: str):
        ctx = [d.page_content for d in vs.similarity_search(q, k=3)]
        prompt = (
            "只能基于以下上下文回答,没有就回答'不知道'。\n"
            f"上下文:\n{chr(10).join(ctx)}\n问题:{q}\n答案:"
        )
        return llm.invoke(prompt), ctx
    return ask
```

