# 0. 通用积木句(所有题都可能用)

```python
from collections import defaultdict, Counter, deque
import heapq, bisect

d = defaultdict(list)                     # 免判断 key 是否存在
c = Counter(nums)                         # 一行统计出现次数
q = deque()                               # 两端 O(1):append/appendleft/pop/popleft
a, b = b, a                               # 交换
for i, x in enumerate(nums): ...          # 同时拿下标和值
grid = [[0]*n for _ in range(m)]          # 二维数组(切勿 [[0]*n]*m)
INF = float('inf')                        # 无穷大做初始最值
res = max(res, cur)                       # 边遍历边更新答案
```

